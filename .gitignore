cat > .gitignore << 'EOF'
# Virtual environment
venv/

# Trained model files (too large for GitHub)
models/*.keras
models/*.h5

# Data files
data/raw/
data/processed/
data/processed.zip
data/raw.zip


# Environment variables
.env

# Python cache
__pycache__/
*.pyc
*.pyo

# VS Code settings
.vscode/

# OS files
.DS_Store
Thumbs.db
EOFmodels/*.task 
